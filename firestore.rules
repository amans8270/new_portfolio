rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Fields: title (string), desc (string), tags (list), github (string), order (number)
    //
    // Collection: skills
    // Fields: name (string), category (string), order (number)
    //
    // Collection: resume
    // Document: main
    // Fields: content (string), downloadUrl (string), updatedAt (string)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "amans8270@gmail.com" && request.auth.token.email_verified == true);
    }

    // Projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Skills
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Resume
    match /resume/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
