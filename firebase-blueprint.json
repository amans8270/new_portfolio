{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "github": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "desc", "order"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A technical skill",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["AI Architecture", "Backend Engine", "Frontend Craft"] },
        "order": { "type": "number" }
      },
      "required": ["name", "category", "order"]
    },
    "Resume": {
      "title": "Resume",
      "description": "Resume metadata and content for RAG",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "Full text content of the resume for RAG context" },
        "downloadUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "updatedAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/skills/{skillId}": {
      "schema": "Skill",
      "description": "Collection of technical skills"
    },
    "/resume/main": {
      "schema": "Resume",
      "description": "Single document containing resume data"
    }
  }
}
